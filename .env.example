# Medical Avatar OSCE Training System - Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=8000

# OpenAI API Keys
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_TTS_API_KEY=sk-proj-YOUR_TTS_KEY_HERE

# ElevenLabs API Key (for better Arabic TTS - optional)
ELEVENLABS_API_KEY=sk_YOUR_KEY_HERE

# Hedra API Configuration (for avatar animation)
HEDRA_API_KEY=sk_hedra_YOUR_KEY_HERE

# LiveKit Configuration (for real-time communication)
LIVEKIT_URL=https://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=YOUR_API_KEY
LIVEKIT_API_SECRET=YOUR_API_SECRET
